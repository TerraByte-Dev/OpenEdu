{
  "identifier": "default",
  "description": "Default capabilities for TerraTutor",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select",
    "store:default",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "store:allow-load",
    "store:allow-delete",
    "store:allow-keys",
    "http:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://localhost:11434/**" },
        { "url": "https://api.openai.com/**" },
        { "url": "https://api.anthropic.com/**" }
      ]
    }
  ]
}
